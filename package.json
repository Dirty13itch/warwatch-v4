{
  "name": "warwatch-v4",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,yellow \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "tsx server/index.ts",
    "dev:web": "vite",
    "build": "npm run build:web && npm run build:api && tsx scripts/generate-build-report.ts",
    "build:web": "vite build",
    "build:api": "node -e \"require('fs').rmSync('dist/server',{recursive:true,force:true})\" && tsc -p tsconfig.server.json",
    "start": "node dist/server/server/index.js",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck",
    "test": "vitest run",
    "integrity": "tsx scripts/verify-integrity.ts",
    "preview:shots": "npm run build && tsx scripts/capture-preview.ts",
    "smoke": "tsx scripts/verify-smoke.ts",
    "verify:public": "tsx scripts/verify-public.ts",
    "verify": "npm run integrity && npm run typecheck && npm run test && npm run build && npm run smoke && npm run verify:public",
    "seed": "tsx scripts/rebuild-db.ts",
    "backfill:entity-tags": "tsx scripts/backfill-entity-tags.ts",
    "ingest:once": "tsx scripts/run-ingest.ts",
    "heartbeat": "tsx scripts/generate-heartbeat-report.ts"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "clsx": "^2.1.1",
    "express": "^5.1.0",
    "maplibre-gl": "^5.9.0",
    "react": "^19.2.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "^19.2.0",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@vitejs/plugin-react-swc": "^4.1.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "jsdom": "^27.0.0",
    "playwright": "^1.59.1",
    "postcss": "^8.5.6",
    "supertest": "^7.1.4",
    "tailwindcss": "^3.4.17",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.2.4"
  }
}
